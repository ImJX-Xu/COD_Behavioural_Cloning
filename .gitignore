# ============================================================
# COD LSTM-BC .gitignore
# ============================================================

# ------------------------------------------------------------
# 数据文件（体积大，不入库）
# ------------------------------------------------------------
*.h5
*.hdf5
data/
COD_BC/data/

# ------------------------------------------------------------
# 模型权重与 checkpoint
# ------------------------------------------------------------
*.pt
*.pth
*.ckpt
*.safetensors
models/
COD_BC/models/

# ------------------------------------------------------------
# TensorBoard 日志
# ------------------------------------------------------------
logs/
COD_BC/logs/
runs/
events.out.tfevents.*

# ------------------------------------------------------------
# config 备份（mouse_bins.py --apply 生成）
# ------------------------------------------------------------
config.bak_*.py
COD_BC/config.bak_*.py

# ------------------------------------------------------------
# Python 运行时产物
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ------------------------------------------------------------
# 虚拟环境
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# ------------------------------------------------------------
# 打包 / 分发
# ------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
*.whl
MANIFEST

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------
# 测试 & 覆盖率
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
*.cover

# ------------------------------------------------------------
# IDE：Cursor / VS Code
# ------------------------------------------------------------
.vscode/
.cursor/
*.code-workspace

# ------------------------------------------------------------
# Windows 系统文件
# ------------------------------------------------------------
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ------------------------------------------------------------
# macOS（协作时用得上）
# ------------------------------------------------------------
.DS_Store
.AppleDouble

# ------------------------------------------------------------
# 临时文件 & 输出截图
# ------------------------------------------------------------
*.tmp
*.temp
*.log
screenshots/
output/
